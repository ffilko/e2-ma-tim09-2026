<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runda 1/2"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30s"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/slagalica_color" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Igrač 1 povezuje pojmove"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Igrač 1: 4  |  Igrač 2: 2"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Poveži izvođače sa naslovima njihovih pesama"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <Button
                            android:id="@+id/btnLeft1"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Bajaga"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnLeft2"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Zdravko Čolić"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnLeft3"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Riblja čorba"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnLeft4"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Marija Šerifović"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnLeft5"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Đorđe Balašević"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <Button
                            android:id="@+id/btnRight1"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Priča o Vasi Ladačkom"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnRight2"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Molitva"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnRight3"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Pogledaj dom svoj, anđele"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnRight4"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Ti se ljubiš"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btnRight5"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Moji drugovi"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/slagalica_color" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSelectedPair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Izabrano: -"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvConnectedPairs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Povezano parova: 0/5"
            android:textStyle="bold"
            android:textColor="@color/slagalica_color"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnClearSelection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Obriši izbor"
                android:textColor="@color/white"
                android:backgroundTint="#FF5722"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnConnectPair"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Poveži par"
                android:textColor="@color/white"
                android:backgroundTint="@color/slagalica_color" />
        </LinearLayout>

        <Button
            android:id="@+id/btnFinishSpojnice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Završi igru"
            android:textColor="@color/white"
            android:backgroundTint="@color/slagalica_color" />

    </LinearLayout>
</ScrollView>