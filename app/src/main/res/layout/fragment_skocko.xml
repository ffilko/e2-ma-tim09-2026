<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="Runda 1/2"/>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/slagalica_color"
                android:text="30.0"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvPhase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Igrač 1 pogađa"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:background="@drawable/rounded_bg"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#DDDDDD"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlayer1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textStyle="bold"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tvScore1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/slagalica_color"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:background="#DDDDDD"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlayer2Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textStyle="bold"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tvScore2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/slagalica_color"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/llBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#20000000"
            android:padding="12dp"
            android:minHeight="120dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="Tvoja kombinacija:"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageView android:id="@+id/ivSlot0" android:layout_width="48dp" android:layout_height="48dp" android:background="@color/white" android:layout_margin="2dp" android:padding="6dp"/>
            <ImageView android:id="@+id/ivSlot1" android:layout_width="48dp" android:layout_height="48dp" android:background="@color/white" android:layout_margin="2dp" android:padding="6dp"/>
            <ImageView android:id="@+id/ivSlot2" android:layout_width="48dp" android:layout_height="48dp" android:background="@color/white" android:layout_margin="2dp" android:padding="6dp"/>
            <ImageView android:id="@+id/ivSlot3" android:layout_width="48dp" android:layout_height="48dp" android:background="@color/white" android:layout_margin="2dp" android:padding="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <ImageButton android:id="@+id/btnSym0" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/skocko"   android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Skočko"/>
            <ImageButton android:id="@+id/btnSym1" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/square"   android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Kvadrat"/>
            <ImageButton android:id="@+id/btnSym2" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/circle"   android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Krug"/>
            <ImageButton android:id="@+id/btnSym3" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/heart"    android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Srce"/>
            <ImageButton android:id="@+id/btnSym4" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/triangle" android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Trougao"/>
            <ImageButton android:id="@+id/btnSym5" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:src="@drawable/star"     android:backgroundTint="@color/slagalica_color" android:layout_margin="2dp" android:padding="10dp" android:scaleType="fitCenter" android:contentDescription="Zvezda"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDeleteSkocko"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/skocko_delete"
                android:backgroundTint="#FF5722"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSubmitSkocko"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/skocko_submit"
                android:backgroundTint="@color/slagalica_color"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>