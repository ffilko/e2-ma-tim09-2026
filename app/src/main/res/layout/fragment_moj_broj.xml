<?xml version="1.0" encoding="utf-8"?>
<!-- 1. Dodajemo ScrollView da omogućiš kretanje gore-dole u landscape režimu -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Zaglavlje (Runda i Timer) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/tvRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="Runda 1/2"/>
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/slagalica_color"
                android:text="5.0"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"
            android:text="Pritisni STOP za traženi broj"/>

        <TextView
            android:id="@+id/tvScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:text="Igrač 1: 0  |  Igrač 2: 0"/>

        <!-- Traženi broj -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text="Traženi broj: "/>
            <TextView
                android:id="@+id/tvTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/slagalica_color"
                android:text="..."/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="Dostupni brojevi:"
            android:layout_marginBottom="4dp"/>

        <GridLayout
            android:id="@+id/gridNumbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="6"
            android:layout_marginBottom="12dp"/>

        <!-- Izraz koji igrač gradi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="Tvoj izraz:"
            android:layout_marginBottom="2dp"/>
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/edit_text"
            android:text=""
            android:layout_marginBottom="8dp"/>

        <!-- Operatori -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">
            <!-- Koristimo težinu 1 i visinu wrap_content radi fleksibilnosti -->
            <Button android:id="@+id/btnPlus"   android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
            <Button android:id="@+id/btnMinus"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="−" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
            <Button android:id="@+id/btnMul"    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="×" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
            <Button android:id="@+id/btnDiv"    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="÷" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
            <Button android:id="@+id/btnLParen" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="(" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
            <Button android:id="@+id/btnRParen" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text=")" android:textSize="18sp" android:layout_margin="2dp" android:backgroundTint="@color/slagalica_color"/>
        </LinearLayout>

        <!-- Briši / Backspace -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Obriši sve"
                android:backgroundTint="#FF5722"/>
            <Button
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="⌫"
                android:backgroundTint="#FF5722"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="STOP"
            android:textSize="18sp"
            android:backgroundTint="@color/slagalica_color"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Potvrdi rešenje"
            android:backgroundTint="@color/slagalica_color"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>